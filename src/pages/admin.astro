---
import Layout from '../layouts/Layout.astro';
import { isValidAdminPassword, generateShareToken, CONTRIBUTOR_PASSWORD } from '../lib/auth';
import { getAllSuggestions, initDatabase } from '../lib/db';

const auth = Astro.cookies.get('auth')?.value;
if (!auth || !isValidAdminPassword(auth)) {
  return Astro.redirect('/');
}

// Initialize database if needed
await initDatabase();

// Get all suggestions
const suggestions = await getAllSuggestions();
const totalSuggestions = suggestions.reduce((acc, row) => acc + Number(row.count), 0);

// Generate share link
const shareToken = generateShareToken(CONTRIBUTOR_PASSWORD);
const shareUrl = `https://namefinder-production.up.railway.app/?token=${shareToken}`;
---

<Layout title="Admin - Namen Übersicht 👶">
  <div class="admin-container">
    <div class="admin-card">
      <div class="header">
        <h1>👶 Namen Übersicht</h1>
        <p class="subtitle">Alle vorgeschlagenen Namen</p>
      </div>

      <div class="stats">
        <div class="stat-box">
          <div class="stat-number">{suggestions.length}</div>
          <div class="stat-label">Verschiedene Namen</div>
        </div>
        <div class="stat-box">
          <div class="stat-number">{totalSuggestions}</div>
          <div class="stat-label">Gesamt-Vorschläge</div>
        </div>
      </div>

      <div class="share-section">
        <h2>🔗 Teile den Link</h2>
        <p>Sende diesen Link an Freunde und Familie:</p>
        <div class="share-box">
          <input
            type="text"
            value={shareUrl}
            readonly
            class="share-input"
            id="shareUrl"
          />
          <button onclick="copyLink()" class="copy-button">
            Kopieren 📋
          </button>
        </div>
      </div>

      {suggestions.length === 0 ? (
        <div class="empty-state">
          <p>😊 Noch keine Namensvorschläge!</p>
          <p>Teile den Link, damit Freunde Namen vorschlagen können.</p>
        </div>
      ) : (
        <div class="names-list">
          <h2>📝 Alle Vorschläge</h2>
          {suggestions.map((row) => (
            <div class="name-card" id={`card-${String(row.name).toLowerCase().replace(/[^a-z0-9]/g, '-')}`}>
              <div class="name-header">
                <span class="name">{row.name}</span>
                <div class="name-actions">
                  <span class="count-badge">{row.count}×</span>
                  <button
                    class="delete-button"
                    data-name={String(row.name)}
                    title="Eintrag löschen"
                  >🗑️</button>
                </div>
              </div>
              {row.suggested_by_list && (
                <div class="suggested-by">
                  von: {row.suggested_by_list}
                </div>
              )}
            </div>
          ))}
        </div>
      )}

      <div class="backup-section">
        <h2>💾 Datensicherung</h2>
        <div class="backup-actions">
          <div class="backup-item">
            <p>Alle Namen als JSON-Datei herunterladen:</p>
            <a href="/api/export" class="backup-button download-button">Exportieren ⬇️</a>
          </div>
          <div class="backup-item">
            <p>Namen aus einer JSON-Datei wiederherstellen:</p>
            <div class="upload-box">
              <input type="file" id="importFile" accept=".json" class="file-input" />
              <button onclick="importData()" class="backup-button upload-button">Importieren ⬆️</button>
            </div>
            <p id="importStatus" class="import-status"></p>
          </div>
        </div>
      </div>

      <a href="/logout" class="logout-link">Abmelden</a>
    </div>
  </div>
</Layout>

<script>
  function copyLink() {
    const input = document.getElementById('shareUrl') as HTMLInputElement;
    input.select();
    document.execCommand('copy');
    alert('Link kopiert! 📋');
  }

  document.querySelectorAll<HTMLButtonElement>('.delete-button').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const name = btn.dataset.name;
      if (!name) return;
      if (!confirm(`"${name}" und alle Einträge dazu wirklich löschen?`)) return;
      const res = await fetch('/api/delete-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (res.ok) {
        btn.closest('.name-card')?.remove();
      } else {
        alert('Löschen fehlgeschlagen.');
      }
    });
  });

  async function importData() {
    const fileInput = document.getElementById('importFile') as HTMLInputElement;
    const status = document.getElementById('importStatus') as HTMLParagraphElement;
    const file = fileInput.files?.[0];
    if (!file) {
      status.textContent = 'Bitte eine Datei auswählen.';
      status.className = 'import-status error';
      return;
    }
    const text = await file.text();
    const res = await fetch('/api/import', { method: 'POST', body: text });
    const json = await res.json();
    if (res.ok) {
      status.textContent = `${json.imported} Einträge importiert.`;
      status.className = 'import-status success';
    } else {
      status.textContent = json.error || 'Import fehlgeschlagen.';
      status.className = 'import-status error';
    }
  }
</script>

<style>
  .admin-container {
    min-height: 100vh;
    padding: 2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .admin-card {
    background: white;
    border-radius: 20px;
    padding: 3rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 800px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
    color: #667eea;
  }

  .subtitle {
    color: #666;
    font-size: 1.1rem;
    margin: 0;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-box {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 1.5rem;
    border-radius: 15px;
    text-align: center;
  }

  .stat-number {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.9rem;
    opacity: 0.9;
  }

  .share-section {
    background: #f5f5f5;
    padding: 1.5rem;
    border-radius: 15px;
    margin-bottom: 2rem;
  }

  .share-section h2 {
    margin: 0 0 1rem 0;
    color: #333;
    font-size: 1.3rem;
  }

  .share-section p {
    margin: 0 0 1rem 0;
    color: #666;
  }

  .share-box {
    display: flex;
    gap: 0.5rem;
  }

  .share-input {
    flex: 1;
    padding: 0.8rem;
    border: 2px solid #e0e0e0;
    border-radius: 10px;
    font-size: 0.9rem;
  }

  .copy-button {
    padding: 0.8rem 1.5rem;
    background: #4caf50;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
  }

  .copy-button:hover {
    background: #45a049;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: #999;
  }

  .names-list h2 {
    margin: 0 0 1.5rem 0;
    color: #333;
    font-size: 1.3rem;
  }

  .name-card {
    background: #f9f9f9;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    padding: 1.2rem;
    margin-bottom: 1rem;
    transition: all 0.2s ease;
  }

  .name-card:hover {
    border-color: #667eea;
    transform: translateX(5px);
  }

  .name-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .name {
    font-size: 1.3rem;
    font-weight: 600;
    color: #333;
  }

  .count-badge {
    background: #667eea;
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: bold;
  }

  .suggested-by {
    color: #999;
    font-size: 0.9rem;
  }

  .name-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .delete-button {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.2rem 0.4rem;
    border-radius: 6px;
    opacity: 0.5;
    transition: opacity 0.2s, background 0.2s;
  }

  .delete-button:hover {
    opacity: 1;
    background: #fee2e2;
  }

  .backup-section {
    background: #f5f5f5;
    padding: 1.5rem;
    border-radius: 15px;
    margin-bottom: 2rem;
  }

  .backup-section h2 {
    margin: 0 0 1rem 0;
    color: #333;
    font-size: 1.3rem;
  }

  .backup-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .backup-item p {
    margin: 0 0 0.8rem 0;
    color: #666;
    font-size: 0.9rem;
  }

  .backup-button {
    display: inline-block;
    padding: 0.7rem 1.2rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .download-button {
    background: #667eea;
    color: white;
  }

  .download-button:hover {
    background: #5a6fd6;
  }

  .upload-button {
    background: #ff9800;
    color: white;
  }

  .upload-button:hover {
    background: #e68900;
  }

  .upload-box {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .file-input {
    font-size: 0.85rem;
    flex: 1;
    min-width: 0;
  }

  .import-status {
    margin: 0.5rem 0 0 0;
    font-size: 0.85rem;
  }

  .import-status.success {
    color: #4caf50;
  }

  .import-status.error {
    color: #f44336;
  }

  .logout-link {
    display: block;
    text-align: center;
    margin-top: 2rem;
    color: #999;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .logout-link:hover {
    color: #667eea;
  }
</style>
