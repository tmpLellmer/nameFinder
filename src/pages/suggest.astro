---
import Layout from '../layouts/Layout.astro';
import { isValidContributorPassword } from '../lib/auth';

const auth = Astro.cookies.get('auth')?.value;
if (!auth || !isValidContributorPassword(auth)) {
  return Astro.redirect('/');
}

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<Layout title="Namen vorschlagen 👶">
  <div class="container">
    <div class="suggest-card">
      <div class="header">
        <h1>👶 Namen vorschlagen</h1>
        <p class="subtitle">Welcher Name könnte zu unserem Baby passen?</p>
      </div>

      {success && (
        <div class="alert success">
          ✨ Super! Dein Vorschlag wurde gespeichert! Vielen Dank! 💝
        </div>
      )}

      {error && (
        <div class="alert error">
          ⚠️ Bitte gib einen Namen ein!
        </div>
      )}

      <form action="/api/suggest" method="POST" class="suggest-form">
        <div class="form-group">
          <label for="name">Name:</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="z.B. Maximilian, Leon, Noah..."
            required
            autofocus
            class="name-input"
          />
        </div>

        <div class="form-group">
          <label for="suggestedBy">Dein Name (optional):</label>
          <input
            type="text"
            id="suggestedBy"
            name="suggestedBy"
            placeholder="Wer schlägt diesen Namen vor?"
            class="name-input"
          />
        </div>

        <button type="submit" class="submit-button">
          Namen vorschlagen 🎉
        </button>
      </form>

      <div class="info">
        <p>💡 Tipp: Du kannst so viele Namen vorschlagen, wie du möchtest!</p>
      </div>

      <a href="/logout" class="logout-link">Abmelden</a>
    </div>
  </div>
</Layout>

<style>
  .container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .suggest-card {
    background: white;
    border-radius: 20px;
    padding: 3rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 500px;
    width: 100%;
  }

  .header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .header h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
    color: #667eea;
  }

  .subtitle {
    color: #666;
    font-size: 1.1rem;
    margin: 0;
  }

  .alert {
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .alert.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .alert.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  .suggest-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    color: #333;
  }

  .name-input {
    padding: 1rem;
    font-size: 1.1rem;
    border: 2px solid #e0e0e0;
    border-radius: 10px;
    transition: all 0.3s ease;
  }

  .name-input:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .submit-button {
    padding: 1rem;
    font-size: 1.2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
    transition: transform 0.2s ease;
  }

  .submit-button:hover {
    transform: translateY(-2px);
  }

  .info {
    margin-top: 1.5rem;
    padding: 1rem;
    background: #f5f5f5;
    border-radius: 10px;
    text-align: center;
    color: #666;
  }

  .logout-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    color: #999;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .logout-link:hover {
    color: #667eea;
  }
</style>
